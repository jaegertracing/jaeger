{
  "method": "POST",
  "path": "/jaeger-span-read/_search",
  "query": {
    "ignore_unavailable": [
      "true"
    ],
    "rest_total_hits_as_int": [
      "true"
    ]
  },
  "body": {
    "aggregations": {
      "traceIDs": {
        "aggregations": {
          "startTime": {
            "max": {
              "field": "startTime"
            }
          }
        },
        "terms": {
          "field": "traceID",
          "order": [
            {
              "startTime": "desc"
            }
          ],
          "size": 20
        }
      }
    },
    "query": {
      "bool": {
        "must": [
          {
            "range": {
              "duration": {
                "gte": 1000000,
                "lte": 60000000
              }
            }
          },
          {
            "range": {
              "startTimeMillis": {
                "gte": 1577934245000,
                "lte": 1577937845000
              }
            }
          },
          {
            "match": {
              "process.serviceName": {
                "query": "test-service"
              }
            }
          },
          {
            "match": {
              "operationName": {
                "query": "test-operation"
              }
            }
          },
          {
            "bool": {
              "should": [
                {
                  "bool": {
                    "must": {
                      "regexp": {
                        "tag.httpstatus_code": {
                          "value": "200"
                        }
                      }
                    }
                  }
                },
                {
                  "bool": {
                    "must": {
                      "regexp": {
                        "process.tag.httpstatus_code": {
                          "value": "200"
                        }
                      }
                    }
                  }
                },
                {
                  "nested": {
                    "path": "tags",
                    "query": {
                      "bool": {
                        "must": [
                          {
                            "match": {
                              "tags.key": {
                                "query": "http.status_code"
                              }
                            }
                          },
                          {
                            "regexp": {
                              "tags.value": {
                                "value": "200"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                },
                {
                  "nested": {
                    "path": "process.tags",
                    "query": {
                      "bool": {
                        "must": [
                          {
                            "match": {
                              "process.tags.key": {
                                "query": "http.status_code"
                              }
                            }
                          },
                          {
                            "regexp": {
                              "process.tags.value": {
                                "value": "200"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                },
                {
                  "nested": {
                    "path": "logs.fields",
                    "query": {
                      "bool": {
                        "must": [
                          {
                            "match": {
                              "logs.fields.key": {
                                "query": "http.status_code"
                              }
                            }
                          },
                          {
                            "regexp": {
                              "logs.fields.value": {
                                "value": "200"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "size": 0
  }
}
