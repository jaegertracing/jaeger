{
  "method": "POST",
  "path": "/jaeger-span-read/_search",
  "query": {
    "ignore_unavailable": [
      "true"
    ]
  },
  "body": {
    "aggregations": {
      "trace_summaries": {
        "aggregations": {
          "error_count": {
            "filter": {
              "bool": {
                "should": [
                  {
                    "bool": {
                      "must": {
                        "regexp": {
                          "tag.error": {
                            "value": "true"
                          }
                        }
                      }
                    }
                  },
                  {
                    "bool": {
                      "must": {
                        "regexp": {
                          "process.tag.error": {
                            "value": "true"
                          }
                        }
                      }
                    }
                  },
                  {
                    "nested": {
                      "path": "tags",
                      "query": {
                        "bool": {
                          "must": [
                            {
                              "match": {
                                "tags.key": {
                                  "query": "error"
                                }
                              }
                            },
                            {
                              "regexp": {
                                "tags.value": {
                                  "value": "true"
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  },
                  {
                    "nested": {
                      "path": "process.tags",
                      "query": {
                        "bool": {
                          "must": [
                            {
                              "match": {
                                "process.tags.key": {
                                  "query": "error"
                                }
                              }
                            },
                            {
                              "regexp": {
                                "process.tags.value": {
                                  "value": "true"
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  },
                  {
                    "nested": {
                      "path": "logs.fields",
                      "query": {
                        "bool": {
                          "must": [
                            {
                              "match": {
                                "logs.fields.key": {
                                  "query": "error"
                                }
                              }
                            },
                            {
                              "regexp": {
                                "logs.fields.value": {
                                  "value": "true"
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                ]
              }
            }
          },
          "max_end": {
            "max": {
              "script": {
                "source": "doc['startTime'].value + doc['duration'].value"
              }
            }
          },
          "max_start": {
            "max": {
              "field": "startTime"
            }
          },
          "min_start": {
            "min": {
              "field": "startTime"
            }
          },
          "root_span": {
            "aggregations": {
              "root_hit": {
                "top_hits": {
                  "_source": {
                    "includes": [
                      "process.serviceName",
                      "operationName"
                    ]
                  },
                  "size": 1,
                  "sort": [
                    {
                      "startTime": {
                        "order": "asc"
                      }
                    }
                  ]
                }
              }
            },
            "filter": {
              "bool": {
                "must_not": {
                  "exists": {
                    "field": "parentSpanID"
                  }
                }
              }
            }
          },
          "services": {
            "aggregations": {
              "service_errors": {
                "filter": {
                  "bool": {
                    "should": [
                      {
                        "bool": {
                          "must": {
                            "regexp": {
                              "tag.error": {
                                "value": "true"
                              }
                            }
                          }
                        }
                      },
                      {
                        "bool": {
                          "must": {
                            "regexp": {
                              "process.tag.error": {
                                "value": "true"
                              }
                            }
                          }
                        }
                      },
                      {
                        "nested": {
                          "path": "tags",
                          "query": {
                            "bool": {
                              "must": [
                                {
                                  "match": {
                                    "tags.key": {
                                      "query": "error"
                                    }
                                  }
                                },
                                {
                                  "regexp": {
                                    "tags.value": {
                                      "value": "true"
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        }
                      },
                      {
                        "nested": {
                          "path": "process.tags",
                          "query": {
                            "bool": {
                              "must": [
                                {
                                  "match": {
                                    "process.tags.key": {
                                      "query": "error"
                                    }
                                  }
                                },
                                {
                                  "regexp": {
                                    "process.tags.value": {
                                      "value": "true"
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        }
                      },
                      {
                        "nested": {
                          "path": "logs.fields",
                          "query": {
                            "bool": {
                              "must": [
                                {
                                  "match": {
                                    "logs.fields.key": {
                                      "query": "error"
                                    }
                                  }
                                },
                                {
                                  "regexp": {
                                    "logs.fields.value": {
                                      "value": "true"
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        }
                      }
                    ]
                  }
                }
              }
            },
            "terms": {
              "field": "process.serviceName",
              "size": 1000
            }
          }
        },
        "terms": {
          "field": "traceID",
          "order": [
            {
              "max_start": "desc"
            }
          ],
          "size": 1
        }
      }
    },
    "query": {
      "bool": {
        "must": [
          {
            "terms": {
              "traceID": [
                "1234567890abcdef"
              ]
            }
          },
          {
            "range": {
              "startTimeMillis": {
                "gte": 1577847845000,
                "lte": 1578024245000
              }
            }
          }
        ]
      }
    },
    "size": 0
  }
}
