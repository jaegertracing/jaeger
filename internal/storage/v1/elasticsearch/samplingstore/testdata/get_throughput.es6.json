{
  "method": "POST",
  "path": "/jaeger-sampling-read/_search",
  "query": {
    "ignore_unavailable": [
      "true"
    ]
  },
  "body": {
    "query": {
      "range": {
        "timestamp": {
          "gte": "2020-01-02T03:04:05Z",
          "lte": "2020-01-02T04:04:05Z"
        }
      }
    },
    "size": 1000
  }
}
